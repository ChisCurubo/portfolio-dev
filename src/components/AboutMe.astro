---
import es from "../json/locales/es.json";
import en from "../json/locales/en.json";

interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const locale = lang === "en" ? en : es;
const { personalImageAlt, paragraphs } = locale.aboutMe;

function parseStrong(text: string) {
  const parts = text.split(/\*\*(.*?)\*\*/g);
  return parts.map((part, i) => (i % 2 === 1 ? { strong: true, text: part } : { strong: false, text: part }));
}
---

<article class="flex flex-col items-center justify-center gap-8 text-white-700 dark:text-white-300 md:flex-row">
  <div
    class="[&>p]:mb-4 [&>p>strong]:text-yellow-500 dark:[&>p>strong]:text-yellow-100 [&>p>strong]:font-normal [&>p>strong]:font-mono text-pretty order-2 md:order-1"
  >
    {
      paragraphs.map((paragraph) => (
        <p>
          {
            parseStrong(paragraph).map((segment) =>
              segment.strong ? <strong>{segment.text}</strong> : segment.text
            )
          }
        </p>
      ))
    }
  </div>

  <img width="200" height="200" src="/portfolio-dev/FotoC.jpg" alt={personalImageAlt} class="order-1 object-cover w-64 h-full p-1 md:order-2 rotate-3 lg:p-2 lg:w-64 aspect-square rounded-2xl bg-black/20 dark:bg-yellow-500/5 ring-1 ring-black/70 dark:ring-white/20 " style="object-position: 50% 50%">
</article>

